# Database
DATABASE_URL="postgresql://user:password@localhost:5432/faculty_tracking_db"

# MySQL (used by bulk CSV import endpoints)
MYSQL_HOST="gateway01.ap-northeast-1.prod.aws.tidbcloud.com"
MYSQL_PORT=3306
MYSQL_USER="3YEHaPmXiTdBCyh.root"
MYSQL_PASSWORD="1RvOoYYf4fcZxdXZ"
MYSQL_DATABASE="ddp"
MYSQL_CONNECTION_LIMIT=10
MYSQL_SSL="true"
MYSQL_SSL_REJECT_UNAUTHORIZED="false"

# JWT
JWT_SECRET="your_jwt_secret_key_change_in_production"
JWT_EXPIRY="24h"

# Server
PORT=5000
NODE_ENV="development"

# Email Configuration
EMAIL_PROVIDER=smtp
SMTP_HOST="your_smtp_server"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="pranavaditya.cs23@bitsathy.ac.in"
SMTP_PASSWORD="your_email_password"
EMAIL_FROM="pranavaditya.cs23@bitsathy.ac.in"
ALERT_NOTIFY_EMAIL="hemasri.it23@bitsathy.ac.in"

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./uploads"
ALLOWED_FILE_TYPES="pdf,jpg,jpeg,png,docx,xlsx"

# CORS
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Logging
LOG_LEVEL="debug"
LOG_DIR="./logs"

# Auth fallback when Prisma is disabled
AUTH_BYPASS="true"
AUTH_BYPASS_ROLES="admin,faculty,verification,hod,dean"
