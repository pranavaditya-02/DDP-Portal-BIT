generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  passwordHash      String
  name              String
  employeeId        String             @unique
  departmentId      Int?
  department        Department?        @relation(fields: [departmentId], references: [id])
  profileImage      String?
  phone             String?
  designation       String?
  joiningDate       DateTime?
  themePreference   String             @default("system")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  userRoles         UserRole[]
  activities        FacultyActivity[]
  verifications     FacultyActivity[]  @relation("VerifiedBy")
  actionPlans       ActionPlan[]
  createdRoles      UserRole[]         @relation("AssignedBy")
  
  @@index([email])
  @@index([departmentId])
}

model Role {
  id          Int       @id @default(autoincrement())
  roleName    String    @unique
  description String?
  createdAt   DateTime  @default(now())
  
  // Relations
  userRoles   UserRole[]
}

model UserRole {
  id            Int       @id @default(autoincrement())
  userId        Int
  roleId        Int
  departmentId  Int?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department    Department? @relation(fields: [departmentId], references: [id])
  isPrimary     Boolean   @default(false)
  assignedAt    DateTime  @default(now())
  assignedBy    Int?
  assignedByUser User?     @relation("AssignedBy", fields: [assignedBy], references: [id])
  isActive      Boolean   @default(true)
  
  @@unique([userId, roleId, departmentId])
  @@index([userId])
  @@index([roleId])
  @@index([departmentId])
}

model Department {
  id            Int       @id @default(autoincrement())
  name          String
  code          String    @unique
  hodUserId     Int?
  hod           User?     @relation(fields: [hodUserId], references: [id])
  totalFaculty  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  
  // Relations
  users         User[]
  userRoles     UserRole[]
  activityTypes ActivityType[]
  targets       ActivityTarget[]
  index         DepartmentIndex[]
  
  @@index([hodUserId])
}

model ActivityType {
  id                Int       @id @default(autoincrement())
  name              String
  category          String    // 'research', 'publication', 'conference', 'workshop', 'fdp', 'admin'
  weightage         Decimal   @db.Decimal(5, 2)
  description       String?
  requiresProof     Boolean   @default(true)
  proofTypesAllowed Json?     // ["pdf", "jpg", "png", "docx"]
  dynamicFields     Json?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  
  // Relations
  activities        FacultyActivity[]
  targets           ActivityTarget[]
  actionPlans       ActionPlan[]
  
  @@index([category])
}

model ActivityTarget {
  id              Int       @id @default(autoincrement())
  departmentId    Int
  activityTypeId  Int
  academicYear    String    // '2025-26'
  targetValue     Int
  department      Department @relation(fields: [departmentId], references: [id])
  activityType    ActivityType @relation(fields: [activityTypeId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([departmentId, activityTypeId, academicYear])
  @@index([departmentId])
  @@index([activityTypeId])
}

model FacultyActivity {
  id                  Int       @id @default(autoincrement())
  facultyId           Int
  activityTypeId      Int
  title               String
  description         String
  activityDate        DateTime
  proofDocumentPath   String?
  status              String    @default("pending") // 'pending', 'approved', 'rejected'
  submittedAt         DateTime  @default(now())
  verifiedBy          Int?
  verifiedByUser      User?     @relation("VerifiedBy", fields: [verifiedBy], references: [id])
  verifiedAt          DateTime?
  rejectionReason     String?
  additionalData      Json?
  pointsEarned        Decimal   @default(0) @db.Decimal(5, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  faculty             User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  activityType        ActivityType @relation(fields: [activityTypeId], references: [id])
  publication         JournalPublication?
  event               Event?
  
  @@index([facultyId])
  @@index([activityTypeId])
  @@index([status])
}

model JournalPublication {
  id              Int       @id @default(autoincrement())
  activityId      Int       @unique
  journalType     String    // 'SCI', 'Scopus', 'UGC', 'Other'
  journalName     String
  impactFactor    Decimal?  @db.Decimal(5, 2)
  issn            String?
  volume          String?
  issue           String?
  pageNumbers     String?
  doi             String?
  coAuthors       Json?
  publicationDate DateTime?
  
  activity        FacultyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  @@index([activityId])
}

model Event {
  id              Int       @id @default(autoincrement())
  activityId      Int       @unique
  eventType       String    // 'conference', 'workshop', 'seminar', 'fdp', 'webinar'
  eventName       String
  organizer       String?
  location        String?
  startDate       DateTime
  endDate         DateTime
  role            String    // 'participant', 'speaker', 'organizer', 'chair'
  participantsCount Int?
  certificatePath String?
  
  activity        FacultyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  @@index([activityId])
}

model DepartmentIndex {
  id                Int       @id @default(autoincrement())
  departmentId      Int
  academicYear      String
  month             Int
  totalTarget       Int
  totalAchieved     Int
  baseIndex         Decimal   @db.Decimal(8, 4)
  additionalIndex   Decimal   @db.Decimal(8, 4)
  normalizedBonus   Decimal   @db.Decimal(8, 4)
  finalIndex        Decimal   @db.Decimal(8, 4)
  rank              Int
  calculatedAt      DateTime  @default(now())
  
  department        Department @relation(fields: [departmentId], references: [id])
  
  @@unique([departmentId, academicYear, month])
  @@index([departmentId])
}

model ActionPlan {
  id              Int       @id @default(autoincrement())
  facultyId       Int
  activityTypeId  Int
  academicYear    String
  plannedCount    Int
  completedCount  Int       @default(0)
  deadline        DateTime?
  status          String    @default("on_track") // 'on_track', 'delayed', 'completed', 'overdue'
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  faculty         User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  activityType    ActivityType @relation(fields: [activityTypeId], references: [id])
  
  @@unique([facultyId, activityTypeId, academicYear])
  @@index([facultyId])
  @@index([activityTypeId])
}

model AuditLog {
  id            Int       @id @default(autoincrement())
  userId        Int?
  action        String
  entity        String
  entityId      Int?
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id            Int       @id @default(autoincrement())
  userId        Int
  title         String
  message       String
  type          String    // 'info', 'success', 'warning', 'error'
  relatedEntity String?
  relatedId     Int?
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([isRead])
}
