// ─────────────────────────────────────────
// ACTIVITY TABLE 13 — MoU
// ─────────────────────────────────────────

Table mou {
  id                          int           [pk, increment]
  submission_id               int           [not null, unique, ref: > submissions.id]
  sig_number                  varchar(50)
  special_labs_involved       boolean       [default: false]
  special_lab_id              int           [ref: > special_lab.id]
  claiming_department_id      int           [ref: > departments.id]
  mou_type_id                 int           [ref: > ref_mou_type.id]
  industry_org_type_id        int           [ref: > ref_industry_org_type.id]
  if_org_type_others          varchar(200)
  mou_based_on_id             int           [ref: > ref_mou_based_on.id]
  domain_area                 varchar(300)
  date_of_agreement           date
  legal_name_collaborator     varchar(300)
  industry_location           varchar(300)
  industry_address            text
  industry_website            varchar(500)
  industry_contact_mobile     varchar(20)
  industry_email              varchar(200)
  duration_unit_id            int           [ref: > ref_mou_duration_unit.id]
  num_years                   int
  num_months                  int
  mou_effect_from             date
  mou_effect_till             date
  scope_of_agreement          text
  objectives_and_goals        text
  boundaries_and_limitations  text
  bit_roles_responsibilities  text
  collaborator_roles          text
  spoc_name                   varchar(200)
  spoc_designation            varchar(200)
  spoc_email                  varchar(200)
  spoc_phone                  varchar(20)
  mou_signing_initiated_by    varchar(200)
  num_faculty                 smallint      [note: '1 | 2 | 3']
  apex_proof_id               int           [ref: > documents.id, note: 'Upload the Apex Proof']
  email_comm_letter_proof_id  int           [ref: > documents.id, note: 'Upload Email Communication / Letter Proof']
  signed_mou_doc_id           int           [ref: > documents.id, note: 'Upload Signed MoU Document']
  parties_rights_doc_id       int           [ref: > documents.id, note: 'Upload Papers showing Party Rights']
  notarized_affidavit_id      int           [ref: > documents.id, note: 'Upload Notarized Affidavit(s) of Nondisclosure']
  geotag_photos_id            int           [ref: > documents.id, note: 'Upload Geotag Photos']
  consolidated_doc_id         int           [ref: > documents.id, note: 'Upload All Documents as Single File']
}

// MoU purpose is multi-select -> junction table
Table mou_purpose {
  id         int [pk, increment]
  mou_id     int [not null, ref: > mou.id]
  purpose_id int [not null, ref: > ref_mou_purpose.id]

  indexes {
    (mou_id, purpose_id) [unique]
  }
}

// MoU faculty (1-3 faculty)
Table mou_faculty {
  id         int         [pk, increment]
  mou_id     int         [not null, ref: > mou.id]
  faculty_id varchar(50) [not null, ref: > faculty.id]
  order_no   smallint    [not null, note: '1 | 2 | 3']

  indexes {
    (mou_id, faculty_id) [unique]
  }
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 14 — IRP VISIT
// ─────────────────────────────────────────

Table irp_visit {
  id                        int           [pk, increment]
  submission_id             int           [not null, unique, ref: > submissions.id]
  sig_number                varchar(50)
  special_labs_involved     boolean       [default: false]
  special_lab_id            int           [ref: > special_lab.id]
  num_faculty               smallint      [note: '1 to 6']
  claimed_for_faculty_id    varchar(50)   [ref: > faculty.id]
  claimed_for_department_id int           [ref: > departments.id]
  approval_type_id          int           [ref: > ref_approval_type.id]
  apex_no                   varchar(100)
  is_mou_related            boolean
  mou_id                    int           [ref: > mou.id, note: 'Required if is_mou_related = true']
  mou_relation_points       text
  from_date                 date
  to_date                   date
  interaction_mode_id       int           [ref: > ref_irp_interaction_mode.id]
  if_mode_others            varchar(200)
  purpose_id                int           [ref: > ref_irp_purpose.id]
  amount_incurred_inrs      decimal(12,2)
  num_industry              smallint      [note: '1 to 6']
  apex_proof_id             int           [ref: > documents.id, note: 'Upload Apex Proof']
  geotag_photos_id          int           [ref: > documents.id, note: 'Upload Geotag Photos']
  irp_form_signed_id        int           [ref: > documents.id, note: 'Upload IRP form duly signed by Industry person']
  consolidated_doc_id       int           [ref: > documents.id, note: 'Upload Consolidated Document']
}

// IRP visit faculty (up to 6)
Table irp_visit_faculty {
  id           int      [pk, increment]
  irp_visit_id int      [not null, ref: > irp_visit.id]
  faculty_id   varchar(50) [not null, ref: > faculty.id]
  order_no     smallint [not null, note: '1 to 6']

  indexes {
    (irp_visit_id, faculty_id) [unique]
  }
}

// IRP visit industries visited (up to 6)
Table irp_visit_industry {
  id                   int          [pk, increment]
  irp_visit_id         int          [not null, ref: > irp_visit.id]
  industry_order       smallint     [not null, note: '1 to 6']
  industry_name        varchar(300)
  industry_type        varchar(100)
  industry_location    varchar(300)
  industry_website     varchar(500)
  contact_person_name  varchar(200)
  contact_designation  varchar(200)
  contact_no           varchar(20)
  contact_email        varchar(200)
}

// Points discussed per industry visit - multi-select
Table irp_industry_points_discussed {
  id                    int [pk, increment]
  irp_visit_industry_id int [not null, ref: > irp_visit_industry.id]
  point_id              int [not null, ref: > ref_irp_points_discussed.id]
}

// Expected outcomes per industry visit - multi-select
Table irp_industry_expected_outcomes {
  id                    int [pk, increment]
  irp_visit_industry_id int [not null, ref: > irp_visit_industry.id]
  outcome_id            int [not null, ref: > ref_irp_points_discussed.id]
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 15 — CONSULTANCY
// ─────────────────────────────────────────

Table consultancy {
  id                            int           [pk, increment]
  submission_id                 int           [not null, unique, ref: > submissions.id]
  special_labs_involved         boolean       [default: false]
  special_lab_id                int           [ref: > special_lab.id]
  claiming_department_id        int           [ref: > departments.id]
  consultant_type_id            int           [ref: > ref_consultancy_type.id]
  sector_id                     int           [ref: > ref_sector_type.id]
  org_name                      varchar(300)
  org_address                   text
  core_sector_id                int           [ref: > ref_core_sector.id]
  project_title                 varchar(300)
  project_category_id           int           [ref: > ref_consultancy_category.id]
  scope_of_work_id              int           [ref: > ref_scope_of_work.id]
  duration_unit_id              int           [ref: > ref_duration_unit.id]
  from_date                     date
  to_date                       date
  is_mou_related                boolean
  mou_id                        int           [ref: > mou.id]
  is_irp_related                boolean
  irp_visit_id                  int           [ref: > irp_visit.id]
  is_fesem_related              boolean
  is_roi_related                boolean
  date_of_payment_1             date
  consultancy_amount_1_inrs     decimal(14,2)
  is_gst_included_1             boolean
  amount_after_gst_1            decimal(14,2)
  ownership_rights_desc         text
  consultant_agreement_desc     text
  date_of_payment_2             date
  college_resources_utilized    boolean
  faculty_share_pct_resources   decimal(5,2)
  institute_share_pct_resources decimal(5,2)
  resources_list                text
  college_transport_utilized    boolean
  transport_area_visited        varchar(300)
  distance_km                   decimal(10,2)
  petrol_cost_per_km            decimal(8,2)
  transport_cost                decimal(12,2)
  consumables_utilized          boolean
  consumables_list              text
  consumables_charge            decimal(12,2)
  faculty_share_pct_no_resources    decimal(5,2)
  institute_share_pct_no_resources  decimal(5,2)
  faculty_share_before_deduction    decimal(14,2)
  institute_share_before_addition   decimal(14,2)
  net_faculty_share_amount      decimal(14,2)
  net_institute_share_amount    decimal(14,2)
  num_faculty_members           int
  consolidated_doc_id           int           [ref: > documents.id, note: 'Upload Consolidated Document']
  rent_agreement_id             int           [ref: > documents.id, note: 'Rent Agreement']
  consultancy_agreement_id      int           [ref: > documents.id, note: 'Upload Consultancy Agreement']
  communication_proof_id        int           [ref: > documents.id, note: 'Upload Communication Proof']
  audit_doc_id                  int           [ref: > documents.id, note: 'Upload Audit Documents Proof (Annexures 1/2)']
  work_logs_id                  int           [ref: > documents.id, note: 'Upload Work Logs Proof']
  invoice_receipt_id            int           [ref: > documents.id, note: 'Upload Invoice Receipt']
  transaction_proof_id          int           [ref: > documents.id, note: 'Upload Transaction Proof']
  geotag_photos_id              int           [ref: > documents.id, note: 'Upload Geotag Photos']
  consultancy_report_id         int           [ref: > documents.id, note: 'Upload Consultancy Report Proof']
  all_consolidated_doc_id       int           [ref: > documents.id, note: 'Consolidated: Comm+Audit+WorkLogs+Invoice+Transaction+Geotag+Report']
  visiting_card_id              int           [ref: > documents.id, note: 'Upload Visiting Card of the Organisation']
  partnership_deed_id           int           [ref: > documents.id, note: 'Upload Partnership Deed Documents Proof']
  noc_premises_id               int           [ref: > documents.id, note: 'Upload NOC of the Business Premises Proof']
  nda_proof_id                  int           [ref: > documents.id, note: 'Upload Non-Disclosure Agreement (Mutual) Proof']
}

// Consultancy faculty (1 primary via submission + up to 4 additional)
Table consultancy_faculty {
  id             int         [pk, increment]
  consultancy_id int         [not null, ref: > consultancy.id]
  faculty_id     varchar(50) [not null, ref: > faculty.id]
  sig_number     varchar(50)
  order_no       smallint    [not null, note: '2 to 5']

  indexes {
    (consultancy_id, faculty_id) [unique]
  }
}

