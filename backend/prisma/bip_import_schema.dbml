  label varchar(100) [not null, unique, note: 'Internship | Centre of Excellence | Faculty Training | World Skills Training | Certification Course | Placement Training | Collaborative Projects | Laboratory Enhancement | Consultancy | Sharing Facilities | Product Development | Publications | Funding | Patents | Organizing Events | Student Projects | One-Credit Course | Placement Offers | Syllabus Framing for Curriculum | Syllabus Framing for One Credit | Student Training | Others']
