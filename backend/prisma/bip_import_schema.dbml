  mou_id                          int           [ref: > mou.id]
  is_irp_related                  boolean
  irp_visit_id                    int           [ref: > irp_visit.id]
  stock_register_maintained       boolean
  total_amount_inrs               decimal(14,2)
  bit_contribution_inrs           decimal(14,2)
  industry_contribution_with_gst  decimal(14,2)
  industry_contribution_no_gst    decimal(14,2)
  students_per_batch              int
  academic_course                 varchar(300)
  syllabus_id                     int           [ref: > documents.id, note: 'Upload Syllabus']
  lab_photo_id                    int           [ref: > documents.id, note: 'Upload Lab Photo']
  communication_proof_id          int           [ref: > documents.id, note: 'Upload Communication Proof']
  apex_document_id                int           [ref: > documents.id, note: 'Upload Apex Document']
  facilities_report_id            int           [ref: > documents.id, note: 'Report of Facilities Available (Word Document)']
  utilization_report_id           int           [ref: > documents.id, note: 'Lab Utilization Report']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 19 — FACULTY TRAINED BY INDUSTRY
// ─────────────────────────────────────────

Table faculty_trained_by_industry {
  id                        int           [pk, increment]
  submission_id             int           [not null, unique, ref: > submissions.id]
  special_labs_involved     boolean       [default: false]
  special_lab_id            int           [ref: > special_lab.id]
  training_program_name     varchar(300)
  financial_assistance_id   int           [ref: > ref_financial_assistance.id]
  amount_incurred_inrs      decimal(12,2)
  approval_type_id          int           [ref: > ref_approval_type_short.id]
  apex_approval_no          varchar(100)
  industry_name             varchar(300)
  domain_area               varchar(300)
  industry_type_id          int           [ref: > ref_industry_org_type.id]
  if_type_others            varchar(200)
  training_mode_id          int           [ref: > ref_training_mode.id]
  training_venue            varchar(300)
  duration_days             int
  start_date                date
  end_date                  date
  industry_website          varchar(500)
  trainer1_name             varchar(200)
  trainer1_designation      varchar(200)
  trainer1_email            varchar(200)
  trainer1_phone            varchar(20)
  has_trainer2              boolean
  trainer2_name             varchar(200)
  trainer2_designation      varchar(200)
  trainer2_email            varchar(200)
  trainer2_phone            varchar(20)
  outcome                   text
  proof_id                  int           [ref: > documents.id, note: 'Apex Approval Copy, Sample Photographs, Training Certificate, Bills/Invoices']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 20 — INDUSTRY ADVISORS
// ─────────────────────────────────────────

Table industry_advisor {
  id                           int           [pk, increment]
  submission_id                int           [not null, unique, ref: > submissions.id]
  sig_number                   varchar(50)
  special_labs_involved        boolean       [default: false]
  special_lab_id               int           [ref: > special_lab.id]
  industry_name                varchar(300)
  domain_area                  varchar(300)
  industry_type_id             int           [ref: > ref_industry_org_type.id]
  if_type_others               varchar(200)
  expert_name                  varchar(200)
  expert_designation           varchar(200)
  expert_email                 varchar(200)
  expert_phone                 varchar(20)
  experience_years             int
  area_of_expertise            varchar(300)
  industry_address             text
  industry_website             varchar(500)
  interaction_frequency_months int
  date_of_meeting              date
  expense_incurred_inrs        decimal(12,2)
  suggestions_for_improvement  text
  collaborative_activities     text
  proof_id                     int           [ref: > documents.id, note: 'Approval Letter, Minutes of Meeting, Sample Photographs, Collaborative Activities']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 21 — LABORATORY DEVELOPED BY INDUSTRY
// ─────────────────────────────────────────

Table lab_developed_by_industry {
  id                               int           [pk, increment]
  submission_id                    int           [not null, unique, ref: > submissions.id]
  sig_number                        varchar(50)
  lab_name                         varchar(300)
  collaborative_industry           varchar(300)
  domain_area                      varchar(300)
  lab_area_sq_m                    decimal(10,2)
  total_amount_inrs                decimal(14,2)
  bit_contribution_inrs            decimal(14,2)
  industry_financial_support_inrs  decimal(14,2)
  any_equipment_sponsored          boolean
  sponsored_equipment_names        text
  any_equipment_enhancement        boolean
  enhanced_equipment_names         text
  layout_design_type_id            int           [ref: > ref_lab_layout_type.id]
  curriculum_mapping               text          [note: 'Course code and name for newly set laboratories']
  expected_outcomes                text
  proof_id                         int           [ref: > documents.id, note: 'Bills & Invoices, Sample Training/Equipment Sponsored, Photographs, Approval Letter']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 22 — STUDENTS INDUSTRIAL VISIT
// ─────────────────────────────────────────

Table students_industrial_visit {
  id                          int           [pk, increment]
  submission_id               int           [not null, unique, ref: > submissions.id]
  sig_number                  varchar(50)
  programme_level_id          int           [ref: > ref_programme_level.id]
  industry_name               varchar(300)
  domain_area                 varchar(300)
  industry_type_id            int           [ref: > ref_industry_org_type.id]
  if_type_others              varchar(200)
  industry_location           varchar(300)
  industry_website            varchar(500)
  contact_person_name         varchar(200)
  contact_designation         varchar(200)
  contact_email               varchar(200)
  contact_phone               varchar(20)
  start_date                  date
  end_date                    date
  purpose_of_visit            text
  num_students_visited        int
  num_male_students           int
  num_female_students         int
  year_of_study_id            int           [ref: > ref_year_of_study.id, note: 'First | Second | Third | Fourth']
  source_of_arrangement_id    int           [ref: > ref_visit_source.id]
  curriculum_mapping          text
  outcome                     text
  proof_id                    int           [ref: > documents.id, note: 'IV Approval Letter, Institute Approval, IV Report with Photos, Student Feedback Samples, Payment Proofs']
}

// Faculty accompanying industrial visit (up to 3)
Table students_iv_faculty {
  id         int      [pk, increment]
  iv_id      int      [not null, ref: > students_industrial_visit.id]
  faculty_id varchar(50) [not null, ref: > faculty.id]
  order_no   smallint [not null, note: '1 to 3']

  indexes {
    (iv_id, faculty_id) [unique]
  }
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 23 — TECHNICAL SOCIETIES & CHAPTERS
// ─────────────────────────────────────────

Table technical_society_dept_mapping {
  id                   int       [pk, increment]
  technical_society_id int       [not null, ref: > ref_technical_society.id]
  department_id        int       [not null, ref: > departments.id]
  status_id            int       [not null, ref: > ref_technical_society_status.id, note: 'Active | Non-Active']
  created_at           timestamp [default: `CURRENT_TIMESTAMP`]
  updated_at           timestamp [default: `CURRENT_TIMESTAMP`]

  indexes {
    (technical_society_id, department_id) [unique]
  }
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 24 — TRAINING TO INDUSTRY PERSONNEL
// ─────────────────────────────────────────

Table training_to_industry {
  id                           int           [pk, increment]
  submission_id                int           [not null, unique, ref: > submissions.id]
  sig_number                   varchar(50)
  special_labs_involved        boolean       [default: false]
  special_lab_id               int           [ref: > special_lab.id]
  event_type_id                int           [ref: > ref_training_event_type.id]
  if_event_type_others         varchar(200)
  industry_name                varchar(300)
  industry_address             text
  domain_area                  varchar(300)
  industry_type_id             int           [ref: > ref_industry_org_type.id]
  if_type_others               varchar(200)
  training_mode_id             int           [ref: > ref_training_mode.id]
  training_venue               varchar(300)
  industry_website             varchar(500)
  num_persons_trained          int
  duration_days                int
  start_date                   date
  end_date                     date
  outcome                      text
  honorarium_received          boolean
  honorarium_amount_inrs       decimal(12,2)
  honorarium_includes_gst      boolean
  amount_after_gst             decimal(12,2)
  college_resources_utilized   boolean
  resources_list               text
  consumable_charges           decimal(12,2)
  college_transport_utilized   boolean
  transport_area               varchar(300)
  distance_km                  decimal(10,2)
  petrol_cost_per_km           decimal(8,2)
  transport_cost               decimal(12,2)
  is_claimed_as_consultancy    boolean
  category_sharing_id          int           [ref: > ref_category_sharing.id]
  faculty_share_before         decimal(14,2)
  institute_share_before       decimal(14,2)
  net_faculty_share            decimal(14,2)
  net_institute_share          decimal(14,2)
  num_faculty_members          int
  share_per_faculty            decimal(14,2) [note: 'Net faculty share / num faculty members']
  communication_proof_id       int           [ref: > documents.id, note: 'Upload Communication Proof']
  approval_letter_id           int           [ref: > documents.id, note: 'Approval Letter from BIT']
  geotag_photos_id             int           [ref: > documents.id, note: 'Upload Geotag Photos']
  participant_attendance_id    int           [ref: > documents.id, note: "Upload Participant's Attendance"]
  payment_proof_id             int           [ref: > documents.id, note: 'Upload Payment Proofs']
  consolidated_doc_id          int           [ref: > documents.id, note: 'Upload Consolidated Document']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 25 — PROFESSIONAL BODY MEMBERSHIP
// ─────────────────────────────────────────

Table professional_body_membership {
  id                       int           [pk, increment]
  submission_id            int           [not null, unique, ref: > submissions.id]
  membership_category_id   int           [not null, ref: > ref_membership_category.id]
  special_labs_involved    boolean       [default: false]
  special_lab_id           int           [ref: > special_lab.id]
  professional_body_name   varchar(300)
  membership_type_id       int           [ref: > ref_membership_type.id]
  membership_id            varchar(100)
  grade_level_position     varchar(200)
  level_id                 int           [ref: > ref_membership_level.id]
  validity_type_id         int           [ref: > ref_membership_validity_type.id]
  apex_document_id         int           [ref: > documents.id, note: 'Apex Document Proof (if applicable)']
  amount_self_bit_inrs     decimal(12,2) [note: 'Amount for Self or BIT validity type']
  if_validity_others       varchar(200)
  amount_others_inrs       decimal(12,2) [note: 'Amount when Validity Type = Others']
  document_proof_id        int           [ref: > documents.id, note: 'Certificate Proof & Apex Proof']
}

