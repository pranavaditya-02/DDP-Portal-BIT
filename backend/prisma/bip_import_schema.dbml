// ACTIVITY TABLE 18 — CENTRE OF EXCELLENCE (COE)
// ─────────────────────────────────────────

Table centre_of_excellence {
  id                              int           [pk, increment]
  submission_id                   int           [not null, unique, ref: > submissions.id]
  sig_number                      varchar(50)
  coe_name                        varchar(300)
