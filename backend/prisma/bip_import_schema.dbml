// PS-FAA Database Schema
// Paste this at https://dbdiagram.io/d

// ─────────────────────────────────────────
// LOOKUP / REFERENCE TABLES
// ─────────────────────────────────────────

Table ref_iqac_status {
  id    int         [pk, increment]
  label varchar(20) [not null, unique, note: 'Initiated | Approved | Rejected']
}

Table ref_event_level {
  id    int         [pk, increment]
  label varchar(60) [not null, unique, note: 'State | National | International | Institute (BIT)']
}

Table ref_event_mode {
  id    int         [pk, increment]
  label varchar(20) [not null, unique, note: 'Online | Offline | Hybrid']
}

Table ref_organizer_type {
  id    int         [pk, increment]
  label varchar(40) [not null, unique, note: 'BIT | Industry | Foreign Institute | Institute in India | Others']
}

Table ref_sponsorship_type {
  id    int         [pk, increment]
  label varchar(30) [not null, unique, note: 'Self | BIT | Funding Agency | Others']
}

Table ref_fund_type {
  id    int         [pk, increment]
  label varchar(30) [not null, unique, note: 'Self | Management | Funding Agency']
}

Table ref_event_type_attended {
  id    int         [pk, increment]
  label varchar(120) [not null, unique, note: 'Certificate course | Conference attended-without presentation | Educational fair | Faculty exchange programme | FDP | Guest Lecture | Non-technical events | One credit course | Orientation programme | Seminar | Session chair | STTP | Summer School | Training | Value-Added course | Webinar | Winter School | Workshop | Hands-On Training | PS-Certification (BIT) | NPTEL-FDP | AICTE-UHV-FDP | Innovation Ambassador- IIC Certificate | CEE-ACO & BEI panelist workshop certificate | Other']
}

Table ref_event_type_organized {
  id    int         [pk, increment]
  label varchar(120) [not null, unique, note: 'HRD Programs | Certificate course | Partial Delivery of Course | Competitions for BIT students | Conference | Faculty training Program | FDP/STTP | Guest Lecture | Hands on training | Leader of the Week | Non Technical Event | One credit course | Orientation program | Refresher Program | Seminar | Technical Events | Webinar | Workshop | Non-Teaching training programme | Others | Symposium | Interaction']
}

Table ref_course_type {
  id    int         [pk, increment]
  label varchar(80) [not null, unique, note: 'AICTE | CEC | CISCO | COURSERA | edX | GOOGLE | IBM | IGNOU | IIMB | INI | NITTTR | MICROSOFT | NMEICT | NPTEL | SWAYAM | ICMR | UDEMY | UGC | AICTE QIP PG certificate Programme | AI Infinity | Oracle | Other']
}

Table ref_journal_indexing {
  id    int         [pk, increment]
  label varchar(20) [not null, unique, note: 'Scopus | Web of Science | SCI | Others']
}

Table ref_recognition_type {
  id    int         [pk, increment]
  label varchar(40) [not null, unique, note: 'Reviewer | Editorial Board Member | Editor in Chief | Advisory board Member | Others']
}

Table ref_external_examiner_purpose {
  id    int         [pk, increment]
  label varchar(80) [not null, unique, note: 'Central Valuation | Flying Squad | Hall invigilator | Practical/Project viva External Examiner | Question Paper Scrutiny | QP Setter | University Representative']
}

Table ref_technical_society {
  id    int          [pk, increment]
  label varchar(100) [not null, unique, note: 'IEEE | CSI | IAENG | SAE | etc.']
}

Table ref_resource_person_category {
  id    int         [pk, increment]
  label varchar(80) [not null, unique, note: 'BoS Member | Chief Guest | Conference Session Chair | DC member | Energy Audit | Examiner - Ph.D Viva voce | External Academic Audit | Internal Academic Audit | Jury member | Quality Expert | Technical Expert | Thesis Evaluator | Interaction | Panel-Member']
}

Table ref_e_content_type {
  id    int         [pk, increment]
  label varchar(80) [not null, unique, note: 'PERSONALIZED_SKILL (PS) | TUTORIAL | E-BOOK | VIDEO LECTURES | ACADEMIC BOOK | ASSESSMENT | ARTICLE | BLOG WRITING | COURSE BOARD GRAPHICS | DATABASE CREATION | E-LEARNING GAME | NPTEL TRANSLATION | PODCAST | SKILL-SCOURCE-BOOK | YOUTUBE-VIDEO | MAGAZINE | NEW METHODOLOGY IN TLP/ASSESSMENT | NEW COURSE IN CURICULLAM | Other']
}

Table ref_newsletter_category {
  id    int         [pk, increment]
  label varchar(40) [not null, unique, note: 'Department Newsletter | Institution Newsletter']
}

// ─────────────────────────────────────────
// CORE ENTITY
// ─────────────────────────────────────────

Table departments {
  id         int          [pk, increment]
  dept_code  varchar(20)  [not null, unique]
  dept_name  varchar(120) [not null, unique]
  status     boolean      [not null, default: true, note: 'true=active, false=inactive']
  created_at timestamp    [default: `CURRENT_TIMESTAMP`]
  updated_at timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table faculty {
  id         varchar(50)  [pk]
  salutation varchar(10)  [not null, note: 'Mr | Mrs | Ms | Dr']
  name       varchar(200) [not null]
  designation varchar(60) [not null, note: 'Assistant Professor Level I | Assistant Professor Level II | Assistant Professor Level III | Associate Professor | Professor']
  department_id int       [ref: > departments.id]
  email      varchar(200)
  created_at timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table users {
  id            int          [pk, increment]
  username      varchar(100) [not null, unique]
  email         varchar(200) [not null, unique]
  password_hash varchar(255) [not null]
  faculty_id    varchar(50)  [unique, ref: > faculty.id, note: 'Optional link for faculty user accounts']
  department_id int          [ref: > departments.id, note: 'Primary department mapping']
  role_id       int          [not null, ref: > roles.id, note: 'Assigned role for page/resource access']
  is_active     boolean      [default: true]
  created_at    timestamp    [default: `CURRENT_TIMESTAMP`]
  updated_at    timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table roles {
  id          int          [pk, increment]
  name        varchar(100) [not null, unique]
  is_active   boolean      [default: true]
  created_at  timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table app_pages {
  id          int          [pk, increment]
  page_key    varchar(120) [not null, unique, note: 'dashboard | activities | achievements.submit | department | roles | etc.']
  page_name   varchar(150) [not null]
  route_path  varchar(255) [not null, unique, note: '/dashboard | /activities | /achievements/submit | etc.']
  created_at  timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table role_page_access {
  id          int       [pk, increment]
  role_id     int       [not null, ref: > roles.id]
  page_id     int       [not null, ref: > app_pages.id]
  created_at  timestamp [default: `CURRENT_TIMESTAMP`]

  indexes {
    (role_id, page_id) [unique]
  }
}

// ─────────────────────────────────────────
// SUPPORT TABLES
// ─────────────────────────────────────────

Table ref_doc_type {
  id    int         [pk, increment]
  label varchar(60) [not null, unique, note: 'document_proof | apex_proof | certificate_proof | geotag_photos | syllabus | course_feedback | proceedings_proof | relevant_proof | marksheet_proof | fdp_proof | photo_proof | award_proof | sample_photographs']
}

Table documents {
  id          int          [pk, increment]
  doc_type_id int          [not null, ref: > ref_doc_type.id]
  file_path   varchar(500) [not null]
  uploaded_at timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table special_lab {
  id         int          [pk, increment]
  code       varchar(20)  [not null, unique, note: 'e.g. SL-001, AI-LAB, IOT-LAB']
  name       varchar(200) [not null]
  is_active  boolean      [default: true]
  created_at timestamp    [default: `CURRENT_TIMESTAMP`]
  updated_at timestamp    [default: `CURRENT_TIMESTAMP`]
}

Table submissions {
  id                   int          [pk, increment]
  task_id              varchar(100) [unique, note: 'Task ID from activity forms (if applicable)']
  remarks              text         [note: 'General remarks/comments for the submission']
  activity_type        varchar(60)  [not null, note: 'newsletter_archive | e_content_developed | events_attended | events_organized | external_examiner | faculty_journal_reviewer | guest_lecture_delivered | international_visit | notable_achievements | online_course | paper_presentation | resource_person | mou | irp_visit | consultancy | external_vip_visit | faculty_industry_project | centre_of_excellence | faculty_trained_by_industry | industry_advisor | lab_developed_by_industry | students_industrial_visit | training_to_industry | professional_body_membership']
  faculty_id           varchar(50)  [ref: > faculty.id, note: 'Nullable for department-level activities like newsletter_archive']
  iqac_verification_id int          [ref: > ref_iqac_status.id]
  created_at           timestamp    [default: `CURRENT_TIMESTAMP`]
  updated_at           timestamp    [default: `CURRENT_TIMESTAMP`]
}


// ─────────────────────────────────────────
// ACTIVITY TABLE 1 — NEWSLETTER ARCHIVE
// ─────────────────────────────────────────

Table newsletter_archive {
  id                       int          [pk, increment]
  submission_id            int          [not null, unique, ref: > submissions.id]
  newsletter_category_id   int          [ref: > ref_newsletter_category.id]
  department_id            int          [ref: > departments.id]
  academic_year            varchar(20)
  date_of_publication      date
  volume_number            int
  issue_number             int
  issue_month              varchar(20)
  num_faculty_editors      int
  num_student_editors      int
  proof_document_id        int          [ref: > documents.id, note: 'Upload the Document']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 2 — E-CONTENT DEVELOPED
// ─────────────────────────────────────────

Table e_content_developed {
  id                   int          [pk, increment]
  submission_id        int          [not null, unique, ref: > submissions.id]
  special_labs_involved boolean     [default: false, note: 'Yes | No']
  special_lab_id       int          [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  e_content_type_id    int          [ref: > ref_e_content_type.id]
  if_others_specify    varchar(200)
  topic_name           varchar(300)
  publisher_name       varchar(200)
  publisher_address    text
  contact_no           varchar(20)
  url_of_content       varchar(500)
  date_of_publication  date
  document_proof_id    int          [ref: > documents.id, note: 'Document Proof']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 3 — EVENTS ATTENDED
// ─────────────────────────────────────────

Table events_attended {
  id                    int           [pk, increment]
  submission_id         int           [not null, unique, ref: > submissions.id]
  special_labs_involved boolean       [default: false, note: 'Yes | No']
  special_lab_id        int           [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  event_type_id         int           [ref: > ref_event_type_attended.id]
  if_event_type_others  varchar(200)
  ps_domain             text
  ps_domain_level       text
  topic_name            varchar(300)
  organizer_type_id     int           [ref: > ref_organizer_type.id]
  industry_name         varchar(300)
  industry_name_select  varchar(300)
  industry_address      text
  institute_name        varchar(300)
  event_level_id        int           [ref: > ref_event_level.id]
  event_title           varchar(300)
  organization_sector   varchar(20)   [note: 'Private | Government']
  event_organizer       varchar(300)
  event_mode_id         int           [ref: > ref_event_mode.id]
  event_location        varchar(300)
  event_duration_unit   varchar(10)   [note: 'Months | Weeks | Hours | Days']
  event_date_from       date
  event_date_to         date
  duration_days         int
  other_organizer_name  varchar(300)
  sponsorship_type_id   int           [ref: > ref_sponsorship_type.id]
  funding_agency_name   varchar(300)
  amount_inrs           decimal(12,2)
  outcome               varchar(100)  [note: 'Programs organized | Development of working Models and prototypes | Funded projects received | Others']
  if_outcome_others     varchar(300)
  apex_proof_id         int           [ref: > documents.id, note: 'Apex Proof']
  certificate_proof_id  int           [ref: > documents.id, note: 'Certificate Proof']
  geotag_photos_id      int           [ref: > documents.id, note: 'Upload Geotag Photos']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 4 — EVENTS ORGANIZED
// ─────────────────────────────────────────

Table events_organized {
  id                         int           [pk, increment]
  submission_id              int           [not null, unique, ref: > submissions.id]
  special_labs_involved      boolean       [default: false, note: 'Yes | No']
  special_lab_id             int           [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  role                       varchar(60)   [note: 'Convener | Co-Convener | Co-ordinator | Organizing Secretary']
  department_id              int           [ref: > departments.id]
  is_iic_event               boolean
  is_iic_uploaded            boolean
  iic_bip_id                 varchar(100)
  is_dept_association        boolean
  is_rnd_organized           boolean
  is_technical_society       boolean
  technical_society_id       int           [ref: > ref_technical_society.id]
  is_mou_outcome             boolean
  mou_bip_id                 varchar(100)
  is_irp_outcome             boolean
  irp_bip_id                 varchar(100)
  is_centre_of_excellence    boolean
  coe_bip_id                 varchar(100)
  is_industry_supported_lab  boolean
  isl_bip_id                 varchar(100)
  event_name                 varchar(300)
  type_of_program            varchar(20)   [note: 'Academic | Non Academic']
  club_society_name          varchar(200)
  event_type_id              int           [ref: > ref_event_type_organized.id]
  if_event_type_others       varchar(200)
  topics_covered             text
  has_conference_proceedings boolean
  publisher_detail           text
  publisher_year             int
  volume_number              int
  issue_number               int
  page_number                varchar(40)
  isbn_number                varchar(30)
  indexing_detail            varchar(200)
  event_category             varchar(100)
  event_organizer            varchar(300)
  event_description          text
  event_mode_id              int           [ref: > ref_event_mode.id]
  event_location             varchar(300)
  start_date                 date
  end_date                   date
  event_duration_days        int
  event_level_id             int           [ref: > ref_event_level.id]
  jointly_organized_with     varchar(60)
  joint_org_name             varchar(300)
  joint_org_address          text
  internal_students_count    int
  internal_faculty_count     int
  external_students_count    int
  external_faculty_count     int
  amount_from_management     boolean
  amount_received_inrs       decimal(12,2)
  has_funding_agency         boolean
  funding_agency_name        varchar(300)
  registration_amount_inrs   decimal(12,2)
  total_sponsored_amount     decimal(12,2)
  total_revenue              decimal(12,2)
  syllabus_id                int           [ref: > documents.id, note: 'Upload the Syllabus']
  course_feedback_id         int           [ref: > documents.id, note: 'Upload the Course Feedback']
  proceedings_proof_id       int           [ref: > documents.id, note: 'Submit the Proceedings proof']
  apex_proof_id              int           [ref: > documents.id, note: 'Apex Proof']
  relevant_proof_id          int           [ref: > documents.id, note: 'Approval letter, Brochure, Attendance sheet, Photos, Feedback']
}

Table event_organized_faculty {
  id                 int         [pk, increment]
  event_organized_id int         [not null, ref: > events_organized.id]
  faculty_id         varchar(50) [not null, ref: > faculty.id]
  role               varchar(60) [note: 'Convener | Co-Convener | Co-ordinator | Organizing Secretary']
}

Table event_organized_student {
  id                 int          [pk, increment]
  event_organized_id int          [not null, ref: > events_organized.id]
  student_name       varchar(200)
  student_ref_id     int
}

Table event_organized_guest {
  id                 int          [pk, increment]
  event_organized_id int          [not null, ref: > events_organized.id]
  guest_number       smallint     [not null, note: '1 to 5']
  institution_type   varchar(60)  [note: 'International | National (Within TamilNadu) | National (Outside TamilNadu)']
  guest_name         varchar(200)
  designation        varchar(200)
  email              varchar(200)
  contact_no         varchar(20)
  organization_detail text
  is_alumni          boolean
  guest_type         varchar(20)  [note: 'Academic | Industry']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 5 — EXTERNAL EXAMINER
// ─────────────────────────────────────────

Table external_examiner {
  id                   int          [pk, increment]
  submission_id        int          [not null, unique, ref: > submissions.id]
  special_labs_involved boolean     [default: false, note: 'Yes | No']
  special_lab_id       int          [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  college_name         varchar(300)
  institute_address    text
  purpose_id           int          [ref: > ref_external_examiner_purpose.id]
  examination_name     varchar(300)
  department_of_qp_id  int          [ref: > departments.id]
  subject_of_qp        varchar(300)
  num_days             int
  from_date            date
  to_date              date
  document_proof_id    int          [ref: > documents.id, note: 'Document Proof']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 6 — FACULTY JOURNAL REVIEWER
// ─────────────────────────────────────────

Table faculty_journal_reviewer {
  id                    int           [pk, increment]
  submission_id         int           [not null, unique, ref: > submissions.id]
  special_labs_involved boolean       [default: false, note: 'Yes | No']
  special_lab_id        int           [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  journal_name          varchar(300)
  indexing_id           int           [ref: > ref_journal_indexing.id]
  if_indexing_others    varchar(200)
  issn_no               varchar(30)
  publisher_name        varchar(200)
  impact_factor         decimal(8,3)
  journal_homepage_url  varchar(500)
  recognition_type_id   int           [ref: > ref_recognition_type.id]
  if_recognition_others varchar(200)
  num_papers_reviewed   int
  review_date           date
  document_proof_id     int           [ref: > documents.id, note: 'Mail/Letter/Certificate as single PDF']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 7 — GUEST LECTURE DELIVERED
// ─────────────────────────────────────────

Table guest_lecture_delivered {
  id                   int          [pk, increment]
  submission_id        int          [not null, unique, ref: > submissions.id]
  special_labs_involved boolean     [default: false, note: 'Yes | No']
  special_lab_id       int          [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  event_type           varchar(100)
  topic                varchar(300)
  event_mode_id        int          [ref: > ref_event_mode.id]
  event_level_id       int          [ref: > ref_event_level.id]
  event_name           varchar(300)
  from_date            date
  to_date              date
  num_days             int
  organization_type_id int          [ref: > ref_organizer_type.id]
  org_name             varchar(300)
  org_address          text
  num_participants     int
  audience_type        varchar(200) [note: 'Students | Teaching Faculty | Non Teaching Faculty | Engineering Trainee | Industry persons | Others']
  document_proof_id    int          [ref: > documents.id, note: 'Request Letter, Confirmation Letter, Brochure']
  apex_proof_id        int          [ref: > documents.id, note: 'Apex Proof']
  sample_photographs_id int         [ref: > documents.id, note: 'Screenshot if online, Photograph if offline']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 8 — INTERNATIONAL VISIT
// ─────────────────────────────────────────

Table international_visit {
  id                   int          [pk, increment]
  submission_id        int          [not null, unique, ref: > submissions.id]
  country_visited      varchar(100)
  purpose_of_visit     text
  from_date            date
  to_date              date
  fund_type_id         int          [ref: > ref_fund_type.id]
  funding_agency_name  varchar(300)
  apex_proof_id        int          [ref: > documents.id, note: 'Apex Proof']
  relevant_proof_id    int          [ref: > documents.id, note: 'Approval letter, Brochure, Attendance sheet, Photos']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 9 — NOTABLE ACHIEVEMENTS & AWARDS
// ─────────────────────────────────────────

Table notable_achievements {
  id                     int           [pk, increment]
  submission_id          int           [not null, unique, ref: > submissions.id]
  special_labs_involved  boolean       [default: false, note: 'Yes | No']
  special_lab_id         int           [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  is_technical_society   boolean
  technical_society_id   int           [ref: > ref_technical_society.id]
  type_of_recognition    varchar(20)   [note: 'Award | Achievement']
  award_type             varchar(100)
  achievement_type       varchar(100)
  award_achievement_name varchar(300)
  organization_type      varchar(20)   [note: 'Government | Private | Others']
  others_organization_name varchar(300)
  org_name               varchar(300)
  awarding_body          varchar(100)
  level_id               int           [ref: > ref_event_level.id]
  received_date          date
  nature_of_recognition  varchar(60)   [note: 'Cash Prize | Certificate | Momento']
  prize_amount_inrs      decimal(12,2)
  photo_proof_id         int           [ref: > documents.id, note: 'Photo Proofs']
  document_proof_id      int           [ref: > documents.id, note: 'Document Proof']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 10 — ONLINE COURSE
// ─────────────────────────────────────────

Table online_course {
  id                   int          [pk, increment]
  submission_id        int          [not null, unique, ref: > submissions.id]
  special_labs_involved boolean     [default: false, note: 'Yes | No']
  special_lab_id       int          [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  mode_of_course       varchar(20)  [note: 'Online | Offline | Hybrid']
  course_type_id       int          [ref: > ref_course_type.id]
  type_of_organizer    varchar(20)  [note: 'Private | Government']
  course_name          varchar(300)
  organization_name    varchar(300)
  organization_address text
  level_of_event_id    int          [ref: > ref_event_level.id]
  duration_unit        varchar(10)  [note: 'Hours | Weeks | Days']
  num_hours            int
  num_weeks            int
  num_days             int
  start_date           date
  end_date             date
  course_category      varchar(60)  [note: 'Proctored-Exam | Self-paced with final assessment | Self-paced without final assessment']
  exam_date            date
  grade_obtained       varchar(20)
  is_approved_fdp      boolean
  sponsorship_type_id  int          [ref: > ref_sponsorship_type.id]
  funding_agency_name  varchar(300)
  claimed_for          varchar(30)  [note: 'FAP | Competency | Not-Applicable']
  marksheet_proof_id   int          [ref: > documents.id, note: 'Upload Mark Sheet Proof']
  fdp_proof_id         int          [ref: > documents.id, note: 'Upload FDP Proof']
  apex_proof_id        int          [ref: > documents.id, note: 'Apex Proof']
  certificate_proof_id int          [ref: > documents.id, note: 'Upload Certificate Proof']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 11 — PAPER PRESENTATION
// ─────────────────────────────────────────

Table paper_presentation {
  id                        int           [pk, increment]
  submission_id             int           [not null, unique, ref: > submissions.id]
  special_labs_involved     boolean       [default: false, note: 'Yes | No']
  special_lab_id            int           [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  has_intl_institute_collab boolean
  institute_name            varchar(300)
  conference_name           varchar(300)
  event_mode_id             int           [ref: > ref_event_mode.id]
  event_location            varchar(300)
  organizer_type_id         int           [ref: > ref_organizer_type.id]
  organizer_name            varchar(300)
  event_level_id            int           [ref: > ref_event_level.id]
  paper_title               varchar(500)
  event_start_date          date
  event_end_date            date
  event_duration_days       int
  published_in_proceedings  boolean
  page_from                 int
  page_to                   int
  sponsorship_type_id       int           [ref: > ref_sponsorship_type.id]
  funding_agency_name       varchar(300)
  amount_inrs               decimal(12,2)
  registration_amount_inrs  decimal(12,2)
  award_received            boolean
  apex_proof_id             int           [ref: > documents.id, note: 'Apex Proof']
  document_proof_id         int           [ref: > documents.id, note: 'Certificate & Proceeding page']
  award_proof_id            int           [ref: > documents.id, note: 'Award Proof']
}

Table paper_presentation_faculty {
  id                    int      [pk, increment]
  paper_presentation_id int      [not null, ref: > paper_presentation.id]
  faculty_id            varchar(50) [not null, ref: > faculty.id]
  author_order          smallint
}

Table paper_presentation_ext_faculty {
  id                    int          [pk, increment]
  paper_presentation_id int          [not null, ref: > paper_presentation.id]
  faculty_name          varchar(300)
  institution           varchar(300)
}

Table paper_presentation_industry {
  id                    int          [pk, increment]
  paper_presentation_id int          [not null, ref: > paper_presentation.id]
  person_name           varchar(300)
  industry_name         varchar(300)
}

Table paper_presentation_student {
  id                    int         [pk, increment]
  paper_presentation_id int         [not null, ref: > paper_presentation.id]
  student_name          varchar(200)
  year_of_study         varchar(10) [note: 'First | Second | Third | Fourth']
}

// ─────────────────────────────────────────
// ACTIVITY TABLE 12 — RESOURCE PERSON
// ─────────────────────────────────────────

Table resource_person {
  id                      int          [pk, increment]
  submission_id           int          [not null, unique, ref: > submissions.id]
  special_labs_involved   boolean      [default: false, note: 'Yes | No']
  special_lab_id          int          [ref: > special_lab.id, note: 'Required if special_labs_involved = true']
  category_id             int          [ref: > ref_resource_person_category.id]
  purpose_of_interaction  text
  panel_name              varchar(200)
  organization_type       varchar(20)  [note: 'Industry | Institute']
  org_name_address        text
  visiting_dept_industry  varchar(200)
  visiting_dept_institute varchar(200)
  num_days                int
  from_date               date
  to_date                 date
  document_proof_id       int          [ref: > documents.id, note: 'Document Proof (PDF - max 2KB)']
}

