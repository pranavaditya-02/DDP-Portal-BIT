                          className="form-select"
                        >
                          <option value="">Select Faculty</option>
                          {FACULTY_LIST.map(faculty => (
                            <option key={faculty} value={faculty}>{faculty}</option>
                          ))}
                        </select>
                      </div>
                    ))}
                  </div>
                )}

                {/* External Faculty Involved */}
                <div>
                  <label className="form-label">Faculty Member from Other Institute *</label>
                  <select
                    value={achievement.paperPresentationData?.externalFacultyInvolved || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'externalFacultyInvolved', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* External Faculty Details - Conditional */}
                {achievement.paperPresentationData?.externalFacultyInvolved === 'Yes' && (
                  <div className="space-y-3 border-l-4 border-blue-400 pl-4">
                    {[1, 2, 3].map(num => (
                      <div key={num} className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="form-label">External Faculty {num} (Name) *</label>
                          <input
                            type="text"
                            value={achievement.paperPresentationData?.[`externalFaculty${num}` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `externalFaculty${num}`, e.target.value)}
                            placeholder={`Faculty ${num} Name`}
                            className="form-input"
                          />
                        </div>
                        <div>
                          <label className="form-label">Institution *</label>
                          <input
                            type="text"
                            value={achievement.paperPresentationData?.[`externalFaculty${num}Institution` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `externalFaculty${num}Institution`, e.target.value)}
                            placeholder="Institution Name"
                            className="form-input"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                {/* Industrial Person Involved */}
                <div>
                  <label className="form-label">Whether Industrial Person Involved *</label>
                  <select
                    value={achievement.paperPresentationData?.industrialPersonInvolved || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'industrialPersonInvolved', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* Industrial Person Details - Conditional */}
                {achievement.paperPresentationData?.industrialPersonInvolved === 'Yes' && (
                  <div className="space-y-3 border-l-4 border-amber-400 pl-4">
                    {[1, 2, 3].map(num => (
                      <div key={num} className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="form-label">Person {num} Name *</label>
                          <input
                            type="text"
                            value={achievement.paperPresentationData?.[`industrialPerson${num}` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `industrialPerson${num}`, e.target.value)}
                            placeholder={`Person ${num} Name`}
                            className="form-input"
                          />
                        </div>
                        <div>
                          <label className="form-label">Industry Name *</label>
                          <input
                            type="text"
                            value={achievement.paperPresentationData?.[`industrialPerson${num}Industry` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `industrialPerson${num}Industry`, e.target.value)}
                            placeholder="Industry Name"
                            className="form-input"
                          />
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                {/* International Collaboration */}
                <div>
                  <label className="form-label">Collaboration with any International Institute / University *</label>
                  <select
                    value={achievement.paperPresentationData?.internationalCollaboration || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'internationalCollaboration', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* International Institute Name - Conditional */}
                {achievement.paperPresentationData?.internationalCollaboration === 'Yes' && (
                  <div>
                    <label className="form-label">Name of International Institute / University *</label>
                    <input
                      type="text"
                      value={achievement.paperPresentationData?.internationalInstituteName || ''}
                      onChange={(e) => handlePaperPresentationChange(achievement.id, 'internationalInstituteName', e.target.value)}
                      placeholder="Enter Institute/University Name"
                      className="form-input"
                    />
                  </div>
                )}

                {/* Conference Title */}
                <div>
                  <label className="form-label">Name of Conference *</label>
                  <input
                    type="text"
                    value={achievement.paperPresentationData?.conferenceTitle || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'conferenceTitle', e.target.value)}
                    placeholder="Enter Conference Title"
                    className="form-input"
                    required
                  />
                </div>

                {/* Event Mode */}
                <div>
                  <label className="form-label">Event Mode *</label>
                  <select
                    value={achievement.paperPresentationData?.eventMode || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventMode', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Event Mode</option>
                    {PAPER_PRESENTATION_EVENT_MODES.map(mode => (
                      <option key={mode} value={mode}>{mode}</option>
                    ))}
                  </select>
                </div>

                {/* Event Organizer */}
                <div>
                  <label className="form-label">Event Organizer *</label>
                  <select
                    value={achievement.paperPresentationData?.eventOrganizer || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventOrganizer', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Event Organizer</option>
                    {PAPER_PRESENTATION_ORGANIZERS.map(organizer => (
                      <option key={organizer} value={organizer}>{organizer}</option>
                    ))}
                  </select>
                </div>

                {/* Event Level */}
                <div>
                  <label className="form-label">Event Level *</label>
                  <select
                    value={achievement.paperPresentationData?.eventLevel || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventLevel', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Event Level</option>
                    {PAPER_PRESENTATION_LEVELS.map(level => (
                      <option key={level} value={level}>{level}</option>
                    ))}
                  </select>
                </div>

                {/* Paper Title */}
                <div>
                  <label className="form-label">Paper Title *</label>
                  <input
                    type="text"
                    value={achievement.paperPresentationData?.paperTitle || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'paperTitle', e.target.value)}
                    placeholder="Enter Paper Title"
                    className="form-input"
                    required
                  />
                </div>

                {/* Event Start Date */}
                <div>
                  <label className="form-label">Event Start Date *</label>
                  <input
                    type="date"
                    value={achievement.paperPresentationData?.eventStartDate || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventStartDate', e.target.value)}
                    className="form-input"
                    required
                  />
                </div>

                {/* Event End Date */}
                <div>
                  <label className="form-label">Event End Date *</label>
                  <input
                    type="date"
                    value={achievement.paperPresentationData?.eventEndDate || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventEndDate', e.target.value)}
                    className="form-input"
                    required
                  />
                </div>

                {/* Event Duration */}
                <div>
                  <label className="form-label">Event Duration (Days) *</label>
                  <input
                    type="number"
                    value={achievement.paperPresentationData?.eventDurationDays || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'eventDurationDays', e.target.value)}
                    placeholder="Enter the duration in days"
                    className="form-input"
                    required
                  />
                </div>

                {/* Paper Published in Proceedings */}
                <div>
                  <label className="form-label">Paper Published in Conference Proceedings *</label>
                  <select
                    value={achievement.paperPresentationData?.paperPublishedInProceedings || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'paperPublishedInProceedings', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* Page From & Page To - Conditional */}
                {achievement.paperPresentationData?.paperPublishedInProceedings === 'Yes' && (
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <label className="form-label">Page From *</label>
                      <input
                        type="text"
                        value={achievement.paperPresentationData?.pageFrom || ''}
                        onChange={(e) => handlePaperPresentationChange(achievement.id, 'pageFrom', e.target.value)}
                        placeholder="From Page Number"
                        className="form-input"
                      />
                    </div>
                    <div>
                      <label className="form-label">Page To *</label>
                      <input
                        type="text"
                        value={achievement.paperPresentationData?.pageTo || ''}
                        onChange={(e) => handlePaperPresentationChange(achievement.id, 'pageTo', e.target.value)}
                        placeholder="To Page Number"
                        className="form-input"
                      />
                    </div>
                  </div>
                )}

                {/* Type of Sponsorship */}
                <div>
                  <label className="form-label">Type of Sponsorship *</label>
                  <select
                    value={achievement.paperPresentationData?.typeOfSponsorship || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'typeOfSponsorship', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Sponsorship Type</option>
                    {PAPER_PRESENTATION_SPONSORSHIP.map(sponsorship => (
                      <option key={sponsorship} value={sponsorship}>{sponsorship}</option>
                    ))}
                  </select>
                </div>

                {/* Students Involved */}
                <div>
                  <label className="form-label">Students Involved *</label>
                  <select
                    value={achievement.paperPresentationData?.studentsInvolved || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'studentsInvolved', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* Students Details - Conditional */}
                {achievement.paperPresentationData?.studentsInvolved === 'Yes' && (
                  <div className="space-y-3 border-l-4 border-emerald-400 pl-4">
                    {['first', 'second', 'third', 'fourth', 'fifth'].map((position, idx) => (
                      <div key={position} className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="form-label">{position.charAt(0).toUpperCase() + position.slice(1)} Student *</label>
                          <select
                            value={achievement.paperPresentationData?.[`${position}Student` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `${position}Student`, e.target.value)}
                            className="form-select"
                          >
                            <option value="">Select Student</option>
                            {STUDENT_OPTIONS.map(student => (
                              <option key={student} value={student}>{student}</option>
                            ))}
                          </select>
                        </div>
                        <div>
                          <label className="form-label">Year of Study *</label>
                          <select
                            value={achievement.paperPresentationData?.[`${position}StudentYear` as keyof PaperPresentationData] as string || ''}
                            onChange={(e) => handlePaperPresentationChange(achievement.id, `${position}StudentYear`, e.target.value)}
                            className="form-select"
                          >
                            <option value="">Select Year</option>
                            {['1st Year', '2nd Year', '3rd Year', '4th Year'].map(year => (
                              <option key={year} value={year}>{year}</option>
                            ))}
                          </select>
                        </div>
                      </div>
                    ))}
                  </div>
                )}

                {/* Registration Amount */}
                <div>
                  <label className="form-label">Registration Amount (in Rs.)</label>
                  <input
                    type="number"
                    value={achievement.paperPresentationData?.registrationAmount || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'registrationAmount', e.target.value)}
                    placeholder="Enter Registration Amount"
                    className="form-input"
                  />
                </div>

                {/* Document Proof */}
                <div>
                  <label className="form-label mb-3">Document Proof (Certificate & Proceeding page if applicable) *</label>
                  <div className="relative">
                    <input
                      type="file"
                      accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                      onChange={(e) => {
                        if (e.target.files?.[0]) {
                          handlePaperPresentationChange(achievement.id, 'documentProof', e.target.files[0])
                        }
                      }}
                      className="hidden"
                      id={`doc-proof-${achievement.id}`}
                      required
                    />
                    <label
                      htmlFor={`doc-proof-${achievement.id}`}
                      className="file-upload-area"
                    >
                      {achievement.paperPresentationData?.documentProofPreview ? (
                        <div className="text-center">
                          <p className="text-sm text-slate-600">{achievement.paperPresentationData.documentProof?.name}</p>
                          <p className="text-xs text-slate-500 mt-1">Click to change</p>
                        </div>
                      ) : (
                        <div className="text-center">
                          <Upload className="w-8 h-8 mx-auto text-slate-400 mb-2" />
                          <p className="text-sm font-medium text-slate-600">Choose File</p>
                          <p className="text-xs text-slate-500 mt-1">Drop file or click to choose</p>
                        </div>
                      )}
                    </label>
                  </div>
                </div>

                {/* Award / Prize Received */}
                <div>
                  <label className="form-label">Award / Cash / Prize Received *</label>
                  <select
                    value={achievement.paperPresentationData?.awardPrizeReceived || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'awardPrizeReceived', e.target.value)}
                    className="form-select"
                    required
                  >
                    <option value="">Select Option</option>
                    {YES_NO_OPTIONS.map(option => (
                      <option key={option} value={option}>{option}</option>
                    ))}
                  </select>
                </div>

                {/* Award Proof - Conditional */}
                {achievement.paperPresentationData?.awardPrizeReceived === 'Yes' && (
                  <div>
                    <label className="form-label mb-3">Award Proof *</label>
                    <div className="relative">
                      <input
                        type="file"
                        accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                        onChange={(e) => {
                          if (e.target.files?.[0]) {
                            handlePaperPresentationChange(achievement.id, 'awardProof', e.target.files[0])
                          }
                        }}
                        className="hidden"
                        id={`award-${achievement.id}`}
                      />
                      <label
                        htmlFor={`award-${achievement.id}`}
                        className="file-upload-area"
                      >
                        {achievement.paperPresentationData?.awardProofPreview ? (
                          <div className="text-center">
                            <p className="text-sm text-slate-600">{achievement.paperPresentationData.awardProof?.name}</p>
                            <p className="text-xs text-slate-500 mt-1">Click to change</p>
                          </div>
                        ) : (
                          <div className="text-center">
                            <Upload className="w-8 h-8 mx-auto text-slate-400 mb-2" />
                            <p className="text-sm font-medium text-slate-600">Choose File</p>
                            <p className="text-xs text-slate-500 mt-1">Drop file or click to choose</p>
                          </div>
                        )}
                      </label>
                    </div>
                  </div>
                )}

                {/* IQAC Verification */}
                <div>
                  <label className="form-label">IQAC Verification *</label>
                  <input
                    type="text"
                    value={achievement.paperPresentationData?.iqacVerification || ''}
                    onChange={(e) => handlePaperPresentationChange(achievement.id, 'iqacVerification', e.target.value)}
                    placeholder="CS10111-PP-08.06.2021"
                    className="form-input"
                    required
                  />
                  <p className="text-xs text-slate-500 mt-1">* Please specify the Proof name only in the following format: CS10111-PP-08.06.2021</p>
                </div>
              </div>
            )}

            {/* Generic Fields (for non-Events Attended, non-Events Organized, non-Guest Lecture, non-Online Course, and non-Paper Presentation) */}
            {achievement.category !== 'Events Attended' && achievement.category !== 'Events Organized' && achievement.category !== 'Guest Lecture Delivered' && achievement.category !== 'Online Course' && achievement.category !== 'Paper Presentation' && (
              <>
                {/* Title */}
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-2">Title *</label>
                  <input
                    type="text"
                    value={achievement.title}
                    onChange={(e) => handleAchievementChange(achievement.id, 'title', e.target.value)}
                    placeholder="Enter achievement title"
                    className="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                    required
                  />
                </div>

                {/* Description */}
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-2">Description</label>
                  <textarea
                    value={achievement.description}
                    onChange={(e) => handleAchievementChange(achievement.id, 'description', e.target.value)}
                    placeholder="Add any additional details about this achievement"
                    rows={3}
                    className="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all resize-none"
                  />
                </div>

                {/* Date */}
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-2">Date *</label>
                  <input
                    type="date"
                    value={achievement.date}
                    onChange={(e) => handleAchievementChange(achievement.id, 'date', e.target.value)}
                    className="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                    required
                  />
                </div>

                {/* Image Upload */}
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-3">Evidence Image *</label>
                  <div className="relative">
                    <input
                      type="file"
                      accept="image/*"
                      onChange={(e) => {
                        if (e.target.files?.[0]) {
                          handleAchievementChange(achievement.id, 'image', e.target.files[0])
                        }
                      }}
                      className="hidden"
                      id={`file-${achievement.id}`}
                      required
                    />
                    <label
                      htmlFor={`file-${achievement.id}`}
                      className="flex items-center justify-center w-full px-4 py-8 border-2 border-dashed border-slate-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors cursor-pointer"
                    >
                      {achievement.imagePreview ? (
                        <div className="text-center">
                          <img src={achievement.imagePreview} alt="Preview" className="max-h-32 mx-auto mb-2 rounded" />
                          <p className="text-sm text-slate-600">Click to change image</p>
                        </div>
                      ) : (
                        <div className="text-center">
                          <Upload className="w-8 h-8 mx-auto text-slate-400 mb-2" />
                          <p className="text-sm font-medium text-slate-600">Click to upload or drag and drop</p>
                          <p className="text-xs text-slate-500 mt-1">PNG, JPG, GIF up to 10MB</p>
                        </div>
                      )}
                    </label>
                  </div>
                </div>
              </>
            )}
          </div>
        ))}

        {/* Add More Button */}
        <button
          type="button"
          onClick={handleAddMore}
          className="w-full flex items-center justify-center gap-2 px-4 py-2 border border-dashed border-blue-300 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors font-medium"
        >
          <Plus className="w-4 h-4" />
          Add Another Achievement
        </button>

        {/* Submit Button */}
        <div className="flex gap-3">
          <button
            type="submit"
            disabled={isSubmitting}
            className="flex-1 bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed font-medium flex items-center justify-center gap-2 transition-colors"
          >
            {isSubmitting ? (
              <>
                <Loader2 className="w-4 h-4 animate-spin" />
                Submitting...
              </>
            ) : (
              <>
                <CheckCircle2 className="w-4 h-4" />
                Submit Achievements
              </>
            )}
          </button>
        </div>
      </form>
    </div>
  )
}
